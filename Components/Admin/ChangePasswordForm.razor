@inject L10n L
@inject GlnStore Store

@if (Visible)
{
    <div class="edi-card mb-3">
        <div class="edi-card-header">@L.De("admin.changePw")</div>
        <div class="p-3">
            <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end;">
                <div>
                    <label class="admin-label">@L.De("admin.user")</label>
                    <input class="form-control form-control-sm admin-input" @bind="_newUser" />
                </div>
                <div>
                    <label class="admin-label">@L.De("admin.newPassword")</label>
                    <input type="password" class="form-control form-control-sm admin-input" @bind="_newPass"
                           @onkeyup="OnKeyUp" />
                </div>
                <div>
                    <label class="admin-label">@L.De("admin.confirmPassword")</label>
                    <input type="password" class="form-control form-control-sm admin-input" @bind="_newPass2"
                           @onkeyup="OnKeyUp" />
                </div>
                <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;">
                    <button class="btn btn-sm btn-primary" @onclick="Save">@L.De("admin.save")</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="Cancel">@L.De("admin.cancel")</button>
                    @if (_msg is not null)
                    {
                        <span style="font-size:.8rem;color:@(_isError ? "#dc3545" : "#28a745");">@_msg</span>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    string  _newUser  = "";
    string  _newPass  = "";
    string  _newPass2 = "";
    string? _msg;
    bool    _isError;

    protected override void OnParametersSet()
    {
        // Pre-fill username each time the form opens
        if (Visible && string.IsNullOrEmpty(_newUser))
            _newUser = Store.IsAuthenticated ? "" : "admin";
    }

    async Task Save()
    {
        _msg = null;
        if (string.IsNullOrWhiteSpace(_newUser))
        {
            _msg = "Benutzername darf nicht leer sein."; _isError = true; return;
        }
        if (string.IsNullOrWhiteSpace(_newPass))
        {
            _msg = "Passwort darf nicht leer sein."; _isError = true; return;
        }
        if (_newPass != _newPass2)
        {
            _msg = "Passwörter stimmen nicht überein."; _isError = true; return;
        }
        await Store.SaveCredentialsAsync(_newUser, _newPass);
        _msg = "✓ Gespeichert"; _isError = false;
        _newPass = _newPass2 = "";
        await Task.Delay(1200);
        await Cancel();
    }

    async Task Cancel()
    {
        _newUser = _newPass = _newPass2 = "";
        _msg = null;
        await OnClose.InvokeAsync();
    }

    async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Save();
        if (e.Key == "Escape") await Cancel();
    }
}

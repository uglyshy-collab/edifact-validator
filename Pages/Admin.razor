    async Task ToggleRule(string code, bool enabled)
    {
        Store.Rules[code] = (Store.Rules.TryGetValue(code, out var r) ? r : new RuleConfig { Code = code })
            with { Enabled = enabled };
        await Store.SaveRulesAsync();
    }

    async Task SetSeverityOverride(string code, string? val)
    {
        Severity? sev = val switch { "Error" => Severity.Error, "Warning" => Severity.Warning, _ => null };
        Store.Rules[code] = (Store.Rules.TryGetValue(code, out var r) ? r : new RuleConfig { Code = code })
            with { Override = sev };
        await Store.SaveRulesAsync();
    }

    async Task EnableAllRules()
    {
        foreach (var key in Store.Rules.Keys.ToList())
            Store.Rules[key] = Store.Rules[key] with { Enabled = true };
        await Store.SaveRulesAsync();
    }

    async Task ResetRules() => await Store.ResetRulesAsync();
    async Task ResetStats()  => await Store.ResetStatsAsync();

    static bool IsRecommendation(string code) =>
        code.StartsWith("WARN_") || code.StartsWith("ORDRSP_WARN_") ||
        code.StartsWith("DESADV_WARN_") || code.StartsWith("INVRPT_WARN_");

    List<KeyValuePair<string, int>> TopErrors() =>
        Store.Stats.RuleFrequency
            .Where(kv => !IsRecommendation(kv.Key))
            .OrderByDescending(kv => kv.Value).Take(8).ToList();

    List<KeyValuePair<string, int>> TopRecommendations() =>
        Store.Stats.RuleFrequency
            .Where(kv => IsRecommendation(kv.Key))
            .OrderByDescending(kv => kv.Value).Take(8).ToList();

    // Mutable wrapper for editing
    class EditableEntry
    {
        public GlnEntry? Original { get; }
        public string Group  { get; set; } = "";
        public int    FilNr  { get; set; }
        public string Name   { get; set; } = "";
        public string Ort    { get; set; } = "";
        public string GlnBy  { get; set; } = "";
        public string GlnIv  { get; set; } = "";
        public string GlnDp  { get; set; } = "";

        public EditableEntry() { }
        public EditableEntry(GlnEntry e)
        {
            Original = e;
            Group = e.Group; FilNr = e.FilNr; Name = e.Name; Ort = e.Ort;
            GlnBy = e.GlnBy; GlnIv = e.GlnIv; GlnDp = e.GlnDp;
        }
        public GlnEntry ToEntry() => new()
        {
            Group = Group, FilNr = FilNr, Name = Name, Ort = Ort,
            GlnBy = GlnBy, GlnIv = GlnIv, GlnDp = GlnDp
        };
    }

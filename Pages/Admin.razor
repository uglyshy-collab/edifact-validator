@page "/admin"
@inject GlnStore Store
@inject HistoryService History
@inject IJSRuntime JS
@inject L10n L
@inject NavigationManager Nav
@using EdifactValidator.Services
@implements IDisposable

<PageTitle>@L.De("admin.title") — @L.De("app.title")</PageTitle>

<div class="edi-app @(_theme == "dark" ? "theme-dark" : "")">
    <header class="edi-header">
        <div class="edi-brand" style="cursor:pointer;" @onclick='() => Nav.NavigateTo("/")'>
            <span class="edi-title">@L.De("app.title")</span>
            <span class="edi-subtitle"><span class="edi-subtitle-label">@ActiveTabLabel</span></span>
        </div>
        <div class="edi-controls">
            <a href="/" class="btn btn-sm btn-outline-light">← @L.De("admin.backToApp")</a>
            <button class="btn btn-sm btn-outline-light" @onclick="ToggleTheme">
                @(_theme == "dark" ? "Hell" : "Dunkel")
            </button>
            @if (Store.IsAuthenticated)
            {
                <span class="edi-controls-sep"></span>
                <button class="btn btn-sm btn-outline-light" @onclick="Store.Logout">@L.De("admin.logout")</button>
            }
        </div>
    </header>

    <main class="edi-main">

        @if (!_ready)
        {
            <div class="edi-spinner">
                <div class="spinner-border" role="status" style="width:2rem;height:2rem;"></div>
            </div>
        }
        else if (!Store.IsAuthenticated)
        {
            @* ── Login ── *@
            <div class="admin-login-wrap">
                <div class="edi-card admin-login-card">
                    <div class="edi-card-header">@L.De("admin.login")</div>
                    <div class="p-4">
                        @if (_loginError)
                        {
                            <div class="edi-alert mb-3">@L.De("admin.loginError")</div>
                        }
                        <div class="mb-3">
                            <label class="form-label admin-label">@L.De("admin.user")</label>
                            <input class="form-control form-control-sm admin-input"
                                   value="@_loginUser"
                                   @oninput="e => _loginUser = e.Value?.ToString() ?? string.Empty"
                                   @onkeyup="OnLoginKey" placeholder="admin" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label admin-label">@L.De("admin.password")</label>
                            <input type="password" class="form-control form-control-sm admin-input"
                                   value="@_loginPass"
                                   @oninput="e => _loginPass = e.Value?.ToString() ?? string.Empty"
                                   @onkeyup="OnLoginKey" />
                        </div>
                        <button class="btn btn-sm btn-primary w-100" @onclick="DoLogin" disabled="@_isLoggingIn">
                            @if (_isLoggingIn)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            @L.De("admin.loginBtn")
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            @* ── Tabs ── *@
            <div class="admin-tabs">
                <button class="admin-tab @(_activeTab == "gln"     ? "active" : "")" @onclick='() => _activeTab = "gln"'>@L.De("admin.tabGln")</button>
                <button class="admin-tab @(_activeTab == "rules"   ? "active" : "")" @onclick='() => _activeTab = "rules"'>@L.De("admin.tabRules")</button>
                <button class="admin-tab @(_activeTab == "stats"   ? "active" : "")" @onclick='() => _activeTab = "stats"'>@L.De("admin.tabStats")</button>
                <button class="admin-tab @(_activeTab == "history" ? "active" : "")" @onclick="OpenHistory">@L.De("admin.tabHistory") @(_historyCount > 0 ? $"({_historyCount})" : "")</button>
            </div>

            @if (_activeTab == "gln")
            {
                <GlnTab ShowCredButton="true" />
            }
            else if (_activeTab == "rules")
            {
                <RulesTab />
            }
            else if (_activeTab == "stats")
            {
                <StatsTab />
            }
            else if (_activeTab == "history")
            {
                <HistoryTab @ref="_historyTab" OnCountChanged="OnHistoryCountChanged" />
            }
        }

    </main>

    <footer class="edi-footer">© porta it-service</footer>
</div>

@code {
    bool   _ready       = false;
    string _theme       = "";
    string _loginUser   = "admin";
    string _loginPass   = "";
    bool   _loginError  = false;
    bool   _isLoggingIn = false;
    string _activeTab   = "gln";
    int    _historyCount = 0;

    HistoryTab? _historyTab;

    string ActiveTabLabel => _activeTab switch {
        "rules"   => "Regeln",
        "stats"   => "Statistiken",
        "history" => "Verlauf",
        _         => "GLN-Daten",
    };

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += Refresh;
        await Store.InitAsync();
        _historyCount = await History.GetCountAsync();
        _theme = await JS.InvokeAsync<string?>("ls.get", "theme") ?? "";
        _ready = true;
    }

    async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "" : "dark";
        await JS.InvokeVoidAsync("setTheme", _theme == "dark");
    }

    async Task OpenHistory()
    {
        _activeTab = "history";
        StateHasChanged();
        await Task.Yield();
        if (_historyTab is not null)
            await _historyTab.LoadAsync();
    }

    void OnHistoryCountChanged(int count) => _historyCount = count;

    void Refresh() => StateHasChanged();

    async Task DoLogin()
    {
        if (_isLoggingIn) return;
        _isLoggingIn = true;
        _loginError  = false;
        StateHasChanged(); // show spinner before blocking computation
        _loginError  = !await Store.LoginAsync(_loginUser, _loginPass);
        _isLoggingIn = false;
    }

    async Task OnLoginKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoLogin();
    }

    public void Dispose()
    {
        Store.Changed -= Refresh;
    }
}

@page "/admin"
@inject GlnStore Store
@inject HistoryService History
@inject IJSRuntime JS
@inject L10n L
@implements IDisposable

<PageTitle>@L["admin.title"] — @L["app.title"]</PageTitle>

<div class="edi-app @(_theme == "dark" ? "theme-dark" : "")">
    <header class="edi-header">
        <div class="edi-brand">
            <span class="edi-title">@L["app.title"]</span>
            <span class="edi-subtitle">@L["admin.title"]</span>
        </div>
        <div class="edi-controls">
            <a href="/" class="btn btn-sm btn-outline-light">← @L["admin.backToApp"]</a>
            <button class="btn btn-sm btn-outline-light" @onclick="ToggleTheme">
                @(_theme == "dark" ? L["theme.light"] : L["theme.dark"])
            </button>
            @if (Store.IsAuthenticated)
            {
                <span class="edi-controls-sep"></span>
                <button class="btn btn-sm btn-outline-light" @onclick="() => _showCredForm = !_showCredForm">⚙ @L["admin.changePw"]</button>
                <button class="btn btn-sm btn-outline-light" @onclick="Store.Logout">@L["admin.logout"]</button>
            }
        </div>
    </header>

    <main class="edi-main">

        @if (!_ready)
        {
            <div class="edi-spinner">
                <div class="spinner-border" role="status" style="width:2rem;height:2rem;"></div>
            </div>
        }
        else if (!Store.IsAuthenticated)
        {
            @* ── Login ── *@
            <div class="admin-login-wrap">
                <div class="edi-card admin-login-card">
                    <div class="edi-card-header">@L["admin.login"]</div>
                    <div class="p-4">
                        @if (_loginError)
                        {
                            <div class="edi-alert mb-3">@L["admin.loginError"]</div>
                        }
                        <div class="mb-3">
                            <label class="form-label admin-label">@L["admin.user"]</label>
                            <input class="form-control form-control-sm admin-input"
                                   value="@_loginUser"
                                   @oninput="e => _loginUser = e.Value?.ToString() ?? string.Empty"
                                   @onkeyup="OnLoginKey" placeholder="admin" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label admin-label">@L["admin.password"]</label>
                            <input type="password" class="form-control form-control-sm admin-input"
                                   value="@_loginPass"
                                   @oninput="e => _loginPass = e.Value?.ToString() ?? string.Empty"
                                   @onkeyup="OnLoginKey" />
                        </div>
                        <button class="btn btn-sm btn-primary w-100" @onclick="DoLogin">@L["admin.loginBtn"]</button>
                    </div>
                </div>
            </div>
        }
        else
        {
            @* ── Tabs ── *@
            <div class="admin-tabs">
                <button class="admin-tab @(_activeTab == "gln"     ? "active" : "")" @onclick='() => _activeTab = "gln"'>@L["admin.tabGln"]</button>
                <button class="admin-tab @(_activeTab == "rules"   ? "active" : "")" @onclick='() => _activeTab = "rules"'>@L["admin.tabRules"]</button>
                <button class="admin-tab @(_activeTab == "stats"   ? "active" : "")" @onclick='() => _activeTab = "stats"'>@L["admin.tabStats"]</button>
                <button class="admin-tab @(_activeTab == "history" ? "active" : "")" @onclick="OpenHistory">@L["admin.tabHistory"] @(_historyCount > 0 ? $"({_historyCount})" : "")</button>
            </div>

            @if (_activeTab == "gln")
            {
                @* ── Toolbar ── *@
                <div class="result-toolbar admin-toolbar">
                    <input class="form-control form-control-sm admin-search" placeholder="@L["admin.search"]"
                           @bind="_search" @bind:event="oninput" />
                    <select class="form-select form-select-sm admin-filter"
                            @bind="_filterGroup">
                        <option value="">@L["admin.allGroups"]</option>
                        @foreach (var g in Groups)
                        { <option value="@g">@g</option> }
                    </select>
                    <div class="admin-toolbar-sep"></div>
                    <button class="btn btn-sm btn-success" @onclick="NewEntry">+ @L["admin.add"]</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ShowResetConfirm">↺ @L["admin.reset"]</button>
                </div>

                @* ── Reset confirmation ── *@
                @if (_confirmReset)
                {
                    <div class="edi-alert" style="display:flex;align-items:center;gap:1rem;">
                        <span>@L["admin.resetConfirm"]</span>
                        <button class="btn btn-sm btn-danger" @onclick="DoReset">@L["admin.resetYes"]</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _confirmReset = false">@L["admin.cancel"]</button>
                    </div>
                }

                @* ── Password change form ── *@
                @if (_showCredForm)
                {
                    <div class="edi-card mb-3">
                        <div class="edi-card-header">@L["admin.changePw"]</div>
                        <div class="p-3" style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end;">
                            <div>
                                <label class="admin-label">@L["admin.user"]</label>
                                <input class="form-control form-control-sm admin-input" @bind="_newUser" />
                            </div>
                            <div>
                                <label class="admin-label">@L["admin.newPassword"]</label>
                                <input type="password" class="form-control form-control-sm admin-input" @bind="_newPass" />
                            </div>
                            <div>
                                <label class="admin-label">@L["admin.confirmPassword"]</label>
                                <input type="password" class="form-control form-control-sm admin-input" @bind="_newPass2" />
                            </div>
                            <button class="btn btn-sm btn-primary" @onclick="SaveCreds">@L["admin.save"]</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showCredForm = false">@L["admin.cancel"]</button>
                            @if (_credMsg is not null)
                            { <span style="font-size:.8rem;color:#28a745;">@_credMsg</span> }
                        </div>
                    </div>
                }

                @* ── Edit / Add form ── *@
                @if (_editing is not null)
                {
                    <div class="edi-card mb-3">
                        <div class="edi-card-header">@(_isNew ? L["admin.add"] : L["admin.edit"])</div>
                        <div class="p-3">
                            <div class="admin-form-grid">
                                <div>
                                    <label class="admin-label">@L["admin.fieldGroup"]</label>
                                    <input class="form-control form-control-sm admin-input" @bind="_editing.Group" />
                                </div>
                                <div>
                                    <label class="admin-label">@L["admin.fieldFilNr"]</label>
                                    <input type="number" class="form-control form-control-sm admin-input" @bind="_editing.FilNr" />
                                </div>
                                <div>
                                    <label class="admin-label">@L["admin.fieldName"]</label>
                                    <input class="form-control form-control-sm admin-input" @bind="_editing.Name" />
                                </div>
                                <div>
                                    <label class="admin-label">@L["admin.fieldOrt"]</label>
                                    <input class="form-control form-control-sm admin-input" @bind="_editing.Ort" />
                                </div>
                                <div>
                                    <label class="admin-label">NAD+BY (@L["invoice.buyer"])</label>
                                    <input class="form-control form-control-sm admin-input font-mono" @bind="_editing.GlnBy" maxlength="13" />
                                </div>
                                <div>
                                    <label class="admin-label">NAD+IV (@L["invoice.invoicee"])</label>
                                    <input class="form-control form-control-sm admin-input font-mono" @bind="_editing.GlnIv" maxlength="13" />
                                </div>
                                <div>
                                    <label class="admin-label">NAD+DP (@L["invoice.delivery"])</label>
                                    <input class="form-control form-control-sm admin-input font-mono" @bind="_editing.GlnDp" maxlength="13" />
                                </div>
                            </div>
                            @if (_editError is not null)
                            { <div class="edi-alert mt-2">@_editError</div> }
                            <div class="mt-3" style="display:flex;gap:.5rem;">
                                <button class="btn btn-sm btn-primary" @onclick="SaveEntry">@L["admin.save"]</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">@L["admin.cancel"]</button>
                            </div>
                        </div>
                    </div>
                }

                @* ── GLN Table ── *@
                <div class="edi-card">
                    <div class="edi-card-header">
                        @L["admin.entries"] (@FilteredEntries.Count())
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm edi-table mb-0">
                            <thead>
                                <tr>
                                    <th>@L["admin.fieldGroup"]</th>
                                    <th>@L["admin.fieldFilNr"]</th>
                                    <th>@L["admin.fieldName"]</th>
                                    <th>@L["admin.fieldOrt"]</th>
                                    <th>NAD+BY</th>
                                    <th>NAD+IV</th>
                                    <th>NAD+DP</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in FilteredEntries)
                                {
                                    <tr>
                                        <td>@e.Group</td>
                                        <td>@e.FilNr</td>
                                        <td>@e.Name</td>
                                        <td>@e.Ort</td>
                                        <td><code>@e.GlnBy</code></td>
                                        <td><code>@e.GlnIv</code></td>
                                        <td><code>@e.GlnDp</code></td>
                                        <td style="white-space:nowrap;">
                                            <button class="btn btn-xs btn-outline-primary me-1" @onclick="() => EditEntry(e)">✎</button>
                                            <button class="btn btn-xs btn-outline-danger" @onclick="() => DeleteEntry(e)">✕</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else if (_activeTab == "rules")
            {
                <div class="result-toolbar admin-toolbar" style="margin-bottom:.5rem;">
                    <div class="rules-subtabs">
                        <button class="rules-subtab @(_rulesSubTab == "invoic"  ? "active" : "")" @onclick='() => _rulesSubTab = "invoic"'>INVOIC</button>
                        <button class="rules-subtab @(_rulesSubTab == "ordrsp"  ? "active" : "")" @onclick='() => _rulesSubTab = "ordrsp"'>ORDRSP</button>
                        <button class="rules-subtab @(_rulesSubTab == "desadv"  ? "active" : "")" @onclick='() => _rulesSubTab = "desadv"'>DESADV</button>
                        <button class="rules-subtab @(_rulesSubTab == "invrpt"  ? "active" : "")" @onclick='() => _rulesSubTab = "invrpt"'>INVRPT</button>
                    </div>
                    <div style="display:flex;gap:.5rem;margin-left:auto;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="EnableAllRules">@L["admin.enableAll"]</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ResetRules">↺ @L["admin.ruleResetAll"]</button>
                    </div>
                </div>

                @foreach (var group in (_rulesSubTab == "ordrsp" ? OrdrspRuleGroups : _rulesSubTab == "desadv" ? DesadvRuleGroups : _rulesSubTab == "invrpt" ? InvrptRuleGroups : InvoicRuleGroups))
                {
                    <div class="edi-card mb-3">
                        <div class="edi-card-header">@group.Key</div>
                        <div class="table-responsive">
                            <table class="table table-sm edi-table mb-0">
                                <thead>
                                    <tr>
                                        <th style="width:120px">@L["admin.ruleCode"]</th>
                                        <th>@L["admin.ruleDesc"]</th>
                                        <th style="width:90px">@L["admin.ruleDefault"]</th>
                                        <th style="width:80px">@L["admin.ruleEnabled"]</th>
                                        <th style="width:120px">@L["admin.ruleSeverity"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ruleCode in group.Value)
                                    {
                                        var cfg = Store.Rules.TryGetValue(ruleCode, out var c) ? c : new RuleConfig { Code = ruleCode };
                                        var defSev = DefaultSeverity(ruleCode);
                                        <tr class="@(!cfg.Enabled ? "rule-disabled" : "")">
                                            <td><code style="font-size:.75rem;">@ruleCode</code></td>
                                            <td style="font-size:.82rem;">@L[RuleMsgKey(ruleCode)]</td>
                                            <td><span class="badge @(defSev == Severity.Error ? "bg-danger" : "bg-warning text-dark")" style="font-size:.7rem;">@defSev</span></td>
                                            <td>
                                                <div class="form-check form-switch mb-0">
                                                    <input class="form-check-input" type="checkbox" checked="@cfg.Enabled"
                                                           @onchange="e => ToggleRule(ruleCode, (bool)(e.Value ?? true))" />
                                                </div>
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm" style="font-size:.75rem;min-width:7.5rem;"
                                                        value="@(cfg.Override.HasValue ? cfg.Override.Value.ToString() : "")"
                                                        @onchange="e => SetSeverityOverride(ruleCode, e.Value?.ToString())">
                                                    <option value="">@L["admin.ruleDefault"]</option>
                                                    <option value="Error">Fehler</option>
                                                    <option value="Warning">Warnung</option>
                                                </select>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
            else if (_activeTab == "history")
            {
                <div class="result-toolbar admin-toolbar" style="margin-bottom:.5rem;flex-wrap:wrap;gap:.4rem;">
                    <input class="form-control form-control-sm admin-search" style="max-width:200px;"
                           placeholder="@L["admin.search"]" @bind="_hSearch" @bind:event="oninput" />
                    <input type="date" class="form-control form-control-sm" style="max-width:140px;"
                           @bind="_hDateFrom" @bind:event="oninput" />
                    <input type="date" class="form-control form-control-sm" style="max-width:140px;"
                           @bind="_hDateTo" @bind:event="oninput" />
                    <label class="d-flex align-items-center gap-1" style="font-size:.82rem;white-space:nowrap;margin-left:.5rem;">
                        <input type="checkbox" @bind="_hOnlyInvalid" /> @L["admin.historyOnlyInvalid"]
                    </label>
                    <label class="d-flex align-items-center gap-1" style="font-size:.82rem;white-space:nowrap;margin-left:.75rem;">
                        <input type="checkbox" @bind="_hOnlyTest" /> @L["admin.historyOnlyTest"]
                    </label>
                    <div style="display:flex;gap:.4rem;margin-left:auto;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ExportHistoryCsv">⬇ CSV</button>
                        <button class="btn btn-sm btn-outline-danger"    @onclick="ClearHistory">✕ @L["admin.historyClear"]</button>
                    </div>
                </div>

                @if (_history is null)
                {
                    <div class="edi-spinner"><div class="spinner-border" role="status" style="width:2rem;height:2rem;"></div></div>
                }
                else if (!HistoryFiltered.Any())
                {
                    <div class="edi-card"><p class="p-3 mb-0" style="color:#888;font-size:.88rem;">@L["admin.noHistory"]</p></div>
                }
                else
                {
                    <div class="edi-card">
                        <div class="edi-card-header">@L["admin.tabHistory"] — @HistoryFiltered.Count() @L["admin.historyEntries"]</div>
                        <div class="table-responsive">
                            <table class="table table-sm edi-table mb-0">
                                <thead>
                                    <tr>
                                        <th style="width:140px">@L["admin.statsTimestamp"]</th>
                                        <th>@L["admin.historyFile"]</th>
                                        <th>@L["admin.statsSeller"]</th>
                                        <th class="text-center">@L["admin.statsIsTest"]</th>
                                        <th class="text-end">@L["admin.statsErrors"]</th>
                                        <th class="text-end">@L["admin.statsWarnings"]</th>
                                        <th>@L["admin.statsStatus"]</th>
                                        <th style="width:30px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rec in HistoryFiltered)
                                    {
                                        var expanded = _expandedId == rec.Id;
                                        <tr class="@(!rec.IsValid ? "row-error" : "")">
                                            <td style="font-size:.78rem;">@rec.Timestamp</td>
                                            <td style="font-size:.78rem;white-space:nowrap;">@rec.FileName</td>
                                            <td style="font-size:.78rem;max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@(rec.SellerName + (string.IsNullOrEmpty(rec.SellerGln) ? "" : " / " + rec.SellerGln))">
                                                @(string.IsNullOrEmpty(rec.SellerName) ? rec.SellerGln : rec.SellerName)
                                            </td>
                                            <td class="text-center">@(rec.IsTest ? "🧪" : "")</td>
                                            <td class="text-end">@(rec.ErrorCount   > 0 ? rec.ErrorCount.ToString()   : "–")</td>
                                            <td class="text-end">@(rec.WarningCount > 0 ? rec.WarningCount.ToString() : "–")</td>
                                            <td><span class="badge @(rec.IsValid ? "bg-success" : "bg-danger")" style="font-size:.7rem;">@L[rec.IsValid ? "result.valid" : "result.invalid"]</span></td>
                                            <td>
                                                @if (rec.Issues.Any())
                                                {
                                                    <button class="btn btn-xs btn-outline-secondary" style="padding:0 4px;font-size:.7rem;"
                                                            @onclick="() => _expandedId = expanded ? -1 : rec.Id">
                                                        @(expanded ? "▲" : "▼")
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                        @if (expanded && rec.Issues.Any())
                                        {
                                            <tr>
                                                <td colspan="8" style="background:#f8f8f8;padding:.5rem 1rem;">
                                                    <table class="table table-sm mb-0" style="font-size:.76rem;">
                                                        <thead><tr><th>Code</th><th>Segment</th><th>Zeile</th><th>Beschreibung</th></tr></thead>
                                                        <tbody>
                                                            @foreach (var issue in rec.Issues)
                                                            {
                                                                <tr class="@(issue.Severity == "Error" ? "row-error" : "row-warn")">
                                                                    <td><code>@issue.Code</code></td>
                                                                    <td>@issue.SegmentTag</td>
                                                                    <td>@(issue.LineNumber > 0 ? issue.LineNumber.ToString() : "–")</td>
                                                                    <td>@L[issue.MessageKey]</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
            else if (_activeTab == "stats")
            {
                <div class="result-toolbar admin-toolbar" style="margin-bottom:.5rem;">
                    <span style="font-size:.85rem;color:#5a8fa8;">@L["admin.tabStats"]</span>
                    <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="ResetStats">↺ @L["admin.statsReset"]</button>
                </div>

                @if (Store.Stats.TotalRuns == 0)
                {
                    <div class="edi-card"><p class="p-3 mb-0" style="color:#888;font-size:.88rem;">@L["admin.noStats"]</p></div>
                }
                else
                {
                    @* KPI Cards *@
                    <div class="stats-cards">
                        <div class="stats-card">
                            <div class="stats-card-value">@Store.Stats.TotalRuns</div>
                            <div class="stats-card-label">@L["admin.statsTotal"]</div>
                        </div>
                        <div class="stats-card">
                            <div class="stats-card-value" style="color:#28a745;">@Store.Stats.TotalValid</div>
                            <div class="stats-card-label">@L["admin.statsValid"]</div>
                        </div>
                        <div class="stats-card">
                            <div class="stats-card-value" style="color:#dc3545;">@(Store.Stats.TotalRuns - Store.Stats.TotalValid)</div>
                            <div class="stats-card-label">@L["admin.statsInvalid"]</div>
                        </div>
                        <div class="stats-card">
                            <div class="stats-card-value">@(Store.Stats.TotalRuns > 0 ? $"{(Store.Stats.TotalRuns - Store.Stats.TotalValid) * 100 / Store.Stats.TotalRuns} %" : "–")</div>
                            <div class="stats-card-label">@L["admin.statsErrorRate"]</div>
                        </div>
                        <div class="stats-card">
                            <div class="stats-card-value" style="color:#f0ad4e;">@Store.Stats.TestFileCount</div>
                            <div class="stats-card-label">@L["admin.statsTests"]</div>
                        </div>
                    </div>

                    @* Häufigste Fehler *@
                    @if (TopErrors() is var topErr && topErr.Count > 0)
                    {
                        var maxErr = topErr[0].Value;
                        <div class="edi-card mb-3">
                            <div class="edi-card-header">@L["admin.statsTopErrors"]</div>
                            <div class="p-3">
                                <div class="stats-rule-grid">
                                @foreach (var kv in topErr)
                                {
                                    <span class="stats-bar-desc" style="white-space:nowrap;" title="@kv.Key">@L[RuleMsgKey(kv.Key)]</span>
                                    <div class="stats-bar-wrap">
                                        <div class="stats-bar" style="width:@(maxErr > 0 ? kv.Value * 100 / maxErr : 0)%"></div>
                                    </div>
                                    <span class="stats-bar-count">@kv.Value</span>
                                }
                                </div>
                            </div>
                        </div>
                    }

                    @* Häufige Empfehlungen *@
                    @if (TopRecommendations() is var topRec && topRec.Count > 0)
                    {
                        var maxRec = topRec[0].Value;
                        <div class="edi-card mb-3">
                            <div class="edi-card-header">@L["admin.statsTopRecs"]</div>
                            <div class="p-3">
                                <div class="stats-rule-grid">
                                @foreach (var kv in topRec)
                                {
                                    <span class="stats-bar-desc" style="white-space:nowrap;" title="@kv.Key">@L[RuleMsgKey(kv.Key)]</span>
                                    <div class="stats-bar-wrap">
                                        <div class="stats-bar stats-bar-warn" style="width:@(maxRec > 0 ? kv.Value * 100 / maxRec : 0)%"></div>
                                    </div>
                                    <span class="stats-bar-count">@kv.Value</span>
                                }
                                </div>
                            </div>
                        </div>
                    }

                    @* Validierungen pro Tag *@
                    @if (Store.Stats.RunsByDate.Any())
                    {
                        <div class="edi-card mb-3">
                            <div class="edi-card-header">@L["admin.statsPerPeriod"]</div>
                            <div class="p-3">
                                @{ var byDate = Store.Stats.RunsByDate.OrderByDescending(kv => kv.Key).Take(14).ToList();
                                   var maxDate = byDate.Any() ? byDate.Max(kv => kv.Value) : 1; }
                                @foreach (var kv in byDate)
                                {
                                    <div class="stats-bar-row">
                                        <span class="stats-bar-label" style="font-size:.75rem;">@kv.Key</span>
                                        <div class="stats-bar-wrap">
                                            <div class="stats-bar stats-bar-date" style="width:@(maxDate > 0 ? kv.Value * 100 / maxDate : 0)%"></div>
                                        </div>
                                        <span class="stats-bar-count">@kv.Value</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @* Haupttester: Verkäufer *@
                    @if (Store.Stats.SellerFrequency.Any())
                    {
                        <div class="edi-card mb-3">
                            <div class="edi-card-header">@L["admin.statsTopSellers"]</div>
                            <div class="p-3">
                                @{ var topSellers = Store.Stats.SellerFrequency.OrderByDescending(kv => kv.Value).Take(10).ToList();
                                   var maxSeller  = topSellers.Any() ? topSellers.Max(kv => kv.Value) : 1; }
                                @foreach (var kv in topSellers)
                                {
                                    <div class="stats-bar-row">
                                        <span class="stats-bar-label" style="font-size:.75rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@kv.Key">@kv.Key</span>
                                        <div class="stats-bar-wrap">
                                            <div class="stats-bar stats-bar-seller" style="width:@(maxSeller > 0 ? kv.Value * 100 / maxSeller : 0)%"></div>
                                        </div>
                                        <span class="stats-bar-count">@kv.Value</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @* Recent runs *@
                    @if (Store.Stats.RecentRuns.Any())
                    {
                        <div class="edi-card">
                            <div class="edi-card-header">@L["admin.statsRecentRuns"]</div>
                            <div class="table-responsive">
                                <table class="table table-sm edi-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>@L["admin.statsTimestamp"]</th>
                                            <th>@L["admin.statsSeller"]</th>
                                            <th class="text-end">@L["admin.statsErrors"]</th>
                                            <th class="text-end">@L["admin.statsWarnings"]</th>
                                            <th>@L["admin.statsStatus"]</th>
                                            <th>@L["admin.statsIsTest"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var run in Store.Stats.RecentRuns)
                                        {
                                            <tr>
                                                <td style="font-size:.82rem;">@run.Timestamp</td>
                                                <td style="font-size:.78rem;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@run.SellerName">@(string.IsNullOrEmpty(run.SellerName) ? "–" : run.SellerName)</td>
                                                <td class="text-end">@(run.ErrorCount > 0 ? run.ErrorCount.ToString() : "–")</td>
                                                <td class="text-end">@(run.WarningCount > 0 ? run.WarningCount.ToString() : "–")</td>
                                                <td><span class="badge @(run.IsValid ? "bg-success" : "bg-danger")" style="font-size:.7rem;">@L[run.IsValid ? "result.valid" : "result.invalid"]</span></td>
                                                <td>@(run.IsTest ? "🧪" : "")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }
            }
        }

    </main>

    <footer class="edi-footer">© porta it-service</footer>
</div>

@code {
    bool   _ready       = false;
    string _theme       = "";
    string _loginUser   = "admin";
    string _loginPass   = "";
    bool   _loginError  = false;
    string _search      = "";
    string _filterGroup = "";
    bool   _confirmReset = false;
    bool   _showCredForm = false;
    string _newUser  = "";
    string _newPass  = "";
    string _newPass2 = "";
    string? _credMsg = null;
    string? _editError = null;
    bool   _isNew = false;
    string _activeTab    = "gln";
    string _rulesSubTab  = "invoic";

    // History tab
    List<ValidationRecord>? _history;
    int     _historyCount  = 0;
    string  _hSearch       = "";
    DateTime? _hDateFrom;
    DateTime? _hDateTo;
    bool    _hOnlyInvalid  = false;
    bool    _hOnlyTest     = false;
    long    _expandedId    = -1;

    IEnumerable<ValidationRecord> HistoryFiltered => (_history ?? Enumerable.Empty<ValidationRecord>())
        .Where(r =>
            (string.IsNullOrEmpty(_hSearch)
                || r.FileName.Contains(_hSearch, StringComparison.OrdinalIgnoreCase)
                || r.SellerName.Contains(_hSearch, StringComparison.OrdinalIgnoreCase)
                || r.SellerGln.Contains(_hSearch, StringComparison.OrdinalIgnoreCase))
            && (!_hOnlyInvalid || !r.IsValid)
            && (!_hOnlyTest    ||  r.IsTest)
            && (_hDateFrom is null || DateTime.TryParseExact(r.Timestamp[..10], "dd.MM.yyyy",
                    System.Globalization.CultureInfo.InvariantCulture,
                    System.Globalization.DateTimeStyles.None, out var d) && d >= _hDateFrom.Value)
            && (_hDateTo   is null || DateTime.TryParseExact(r.Timestamp[..10], "dd.MM.yyyy",
                    System.Globalization.CultureInfo.InvariantCulture,
                    System.Globalization.DateTimeStyles.None, out var d2) && d2 <= _hDateTo.Value.AddDays(1)));

    EditableEntry? _editing;

    IEnumerable<string> Groups => Store.Entries.Select(e => e.Group).Distinct().OrderBy(g => g);

    IEnumerable<GlnEntry> FilteredEntries => Store.Entries
        .Where(e => (string.IsNullOrEmpty(_filterGroup) || e.Group == _filterGroup)
                 && (string.IsNullOrEmpty(_search)
                     || e.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                     || e.Group.Contains(_search, StringComparison.OrdinalIgnoreCase)
                     || e.GlnBy.Contains(_search)
                     || e.GlnIv.Contains(_search)
                     || e.GlnDp.Contains(_search)
                     || e.FilNr.ToString().Contains(_search)))
        .OrderBy(e => e.Group).ThenBy(e => e.FilNr);

    protected override async Task OnInitializedAsync()
    {
        L.Changed += Refresh;
        Store.Changed += Refresh;
        L.Set("de");
        await Store.InitAsync();
        _historyCount = await History.GetCountAsync();
        _theme = await JS.InvokeAsync<string?>("ls.get", "theme") ?? "";
        _ready = true;
    }

    async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "" : "dark";
        await JS.InvokeVoidAsync("ls.set", "theme", _theme);
    }

    async Task OpenHistory()
    {
        _activeTab = "history";
        if (_history is null)
        {
            _history = await History.GetRecentAsync(500);
            _historyCount = _history.Count;
        }
    }

    async Task ExportHistoryCsv() => await History.DownloadCsvAsync(JS);

    async Task ClearHistory()
    {
        await History.ClearAsync();
        _history      = new();
        _historyCount = 0;
        _expandedId   = -1;
    }

    void Refresh() => StateHasChanged();

    void DoLogin()
    {
        _loginError = !Store.Login(_loginUser, _loginPass);
    }

    void OnLoginKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") DoLogin();
    }

    void NewEntry()
    {
        _isNew = true;
        _editError = null;
        _editing = new EditableEntry();
    }

    void EditEntry(GlnEntry e)
    {
        _isNew = false;
        _editError = null;
        _editing = new EditableEntry(e);
    }

    async Task SaveEntry()
    {
        if (_editing is null) return;
        if (string.IsNullOrWhiteSpace(_editing.Group) || string.IsNullOrWhiteSpace(_editing.Name))
        {
            _editError = "Firma und Name sind Pflichtfelder.";
            return;
        }
        var entry = _editing.ToEntry();
        if (_isNew)
            await Store.AddAsync(entry);
        else
            await Store.UpdateAsync(_editing.Original!, entry);
        _editing = null;
    }

    void CancelEdit() => _editing = null;

    async Task DeleteEntry(GlnEntry e)
    {
        await Store.DeleteAsync(e);
    }

    void ShowResetConfirm() => _confirmReset = true;

    async Task DoReset()
    {
        _confirmReset = false;
        await Store.ResetToDefaultsAsync();
    }

    async Task SaveCreds()
    {
        _credMsg = null;
        if (string.IsNullOrWhiteSpace(_newUser) || string.IsNullOrWhiteSpace(_newPass))
        { _credMsg = "Benutzername und Passwort dürfen nicht leer sein."; return; }
        if (_newPass != _newPass2)
        { _credMsg = "Passwörter stimmen nicht überein."; return; }
        await Store.SaveCredentialsAsync(_newUser, _newPass);
        _credMsg = "✓ Gespeichert";
        _newPass = _newPass2 = "";
        _showCredForm = false;
    }

    public void Dispose()
    {
        L.Changed -= Refresh;
        Store.Changed -= Refresh;
    }

    // Rule helpers
